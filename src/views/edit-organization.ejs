<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/edit-organization/<%= formData.organization_id %>" method="POST" class="form">
        <div class="form-group">
            <label for="name">Organization Name</label>
            <input type="text" id="name" name="name" value="<%= formData.name || '' %>" maxlength="150" required>
        </div>
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4" required><%= formData.description || '' %></textarea>
        </div>
        <div class="form-group">
            <label for="contact_email">Contact Email</label>
            <input type="email" id="contact_email" name="contact_email" value="<%= formData.contact_email || '' %>" required>
        </div>
        <div class="form-group">
            <label for="logo_filename">Logo Filename</label>
            <input type="text" id="logo_filename" name="logo_filename" value="<%= formData.logo_filename || '' %>" required>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn">Save Changes</button>
            <a href="/organizations" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

<%- include('partials/footer') %>
