<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/new-project" method="POST" class="form">
        <div class="form-group">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" value="<%= formData.title || '' %>" maxlength="150" required>
        </div>
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4" required><%= formData.description || '' %></textarea>
        </div>
        <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" value="<%= formData.location || '' %>" maxlength="255" required>
        </div>
        <div class="form-group">
            <label for="date">Date</label>
            <input type="date" id="date" name="date" value="<%= formData.date || '' %>" required>
        </div>
        <div class="form-group">
            <label for="organization_id">Organization</label>
            <select id="organization_id" name="organization_id" required>
                <option value="">-- Select an Organization --</option>
                <% organizations.forEach(org => { %>
                    <option value="<%= org.organization_id %>" <%= String(formData.organization_id) === String(org.organization_id) ? 'selected' : '' %>>
                        <%= org.name %>
                    </option>
                <% }); %>
            </select>
        </div>
        <div class="form-group">
            <label>Categories</label>
            <div class="checkbox-group">
                <% categories.forEach(cat => { %>
                    <label class="checkbox-label">
                        <input type="checkbox" name="categories" value="<%= cat.category_id %>"
                            <%= (formData.categories || []).includes(String(cat.category_id)) ? 'checked' : '' %>>
                        <%= cat.name %>
                    </label>
                <% }); %>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn">Create Project</button>
            <a href="/projects" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

<%- include('partials/footer') %>
