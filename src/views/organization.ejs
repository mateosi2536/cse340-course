<%- include('partials/header') %>

<main>
    <h1><%= organization.name %></h1>
    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
    <p><%= organization.description %></p>
    <p><%= organization.contact_email %></p>

    <h2>Service Projects</h2>
    <ul>
        <% projects.forEach(project => { %>
            <li><a href="/project/<%= project.project_id %>"><%= project.title %></a></li>
        <% }); %>
    </ul>

    <a href="/edit-organization/<%= organization.organization_id %>" class="btn">Edit Organization</a>
</main>

<%- include('partials/footer') %>
