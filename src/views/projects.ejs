<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <a href="/new-project" class="btn">Add New Project</a>
    <ul>
        <% projects.forEach(project => { %>
            <li>
                <%= new Date(project.date).toLocaleDateString() %>:
                <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
                <a href="/edit-project/<%= project.project_id %>" class="btn btn-secondary">Edit</a>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>
